{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noEmitOnError": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2024",
    "tsBuildInfoFile": "../../target/typescript/organization-console.tsbuildinfo",
    "types": ["node", "vite/client", "vitest/globals"]
  },
  "include": ["src", "console-surface.json", "vite.config.ts"]
}
